#!/usr/bin/env python3

import os
import sys
import shlex
import subprocess

current_user = os.getuid()
home = os.getenv("SUDO_HOME", os.getenv("HOME"))
flake_dir = os.path.join(home, '.dotfiles', 'nixos')

def run(*args: str):
	cmd = shlex.join(args)
	print(f'>> run {cmd}', file=sys.stderr)
	subprocess.run(args, check=True)

os.chdir(flake_dir)

if 'hide' in sys.argv:
    run('git', 'add', '--intent-to-add', '--force', 'host-home-manager.nix')
    run('git', 'update-index', '--skip-worktree', '--assume-unchanged', 'host-home-manager.nix')
if 'restore' in sys.argv:
    run('git', 'update-index', '--skip-worktree', '--no-assume-unchanged', 'host-home-manager.nix')
    run('git', 'restore', '--staged', 'host-home-manager.nix')
